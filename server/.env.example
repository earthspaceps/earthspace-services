PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/earthspace_db

# JWT
JWT_SECRET=earthspace_jwt_secret_change_in_production_2024
JWT_REFRESH_SECRET=earthspace_refresh_secret_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Email (Nodemailer / Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@earthspaceservices.com
SMTP_PASS=your_smtp_password

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# WhatsApp (Twilio/Meta)
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01
WHATSAPP_FROM=whatsapp:+14155238886

# File Upload
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads/
